# Server
PORT=3000
LOG_LEVEL=info

# Stellar Network
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Database (required for persistent mode)
DATABASE_URL=postgresql://cargoledger:cargoledger@localhost:5432/cargoledger

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Webhook signing secret (required for webhook delivery)
CARGOLEDGER_WEBHOOK_SECRET=change-me-in-production

# Auth
JWT_SECRET=change-me-in-production

# Indexer
INDEXER_STALL_THRESHOLD_MS=60000
INDEXER_SAFETY_MARGIN_LEDGERS=1
